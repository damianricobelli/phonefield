{
  "name": "phonefield",
  "version": "1.0.2",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "description": "Composable phone field primitive built with Base UI and libphonenumber-js.",
  "keywords": [
    "react",
    "phone-input",
    "phone-number",
    "base-ui",
    "libphonenumber"
  ],
  "author": "damianricobelli",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/damianricobelli/phonefield.git",
    "directory": "packages/phonefield"
  },
  "homepage": "https://phonefield.vercel.app",
  "sideEffects": false,
  "files": [
    "dist",
    "LICENSE",
    "MIGRATION.md"
  ],
  "engines": {
    "node": ">=22"
  },
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./utils": {
      "types": "./dist/public-utils.d.ts",
      "import": "./dist/utils.js",
      "default": "./dist/utils.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsup && node scripts/verify-package.mjs",
    "check": "biome check src tests scripts",
    "dev": "tsup --watch",
    "lint": "biome lint src tests scripts",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm run build",
    "test": "vitest run"
  },
  "peerDependencies": {
    "@base-ui/react": ">=1.6.0 <2",
    "react": ">=19 <20",
    "react-dom": ">=19 <20"
  },
  "dependencies": {
    "libphonenumber-js": "^1.13.9"
  },
  "devDependencies": {
    "@base-ui/react": "^1.6.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "jsdom": "^29.1.1",
    "tsup": "^8.5.1",
    "typescript": "catalog:",
    "vitest": "^4.1.10"
  }
}
